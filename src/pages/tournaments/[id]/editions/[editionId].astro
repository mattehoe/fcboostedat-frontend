---
export const prerender = false
import Layout from '../../../../layouts/Layout.astro'
import { fetchCollection, getImageUrl } from '../../../../directus.js'

const { id, editionId } = Astro.params


const edition = await fetchCollection('tournaments',
  `/${editionId}?fields=*,event.*,teams.teams_id.*,teams.placement,matches.*,matches.home_team.*,matches.away_team.*`)

const formatDate = (dateStr) => new Date(dateStr).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
})

const ourTeamName = 'FC Boosted'

const getResult = (match) => {
  const weAreHome = match.home_team.name === ourTeamName
  const ourScore = weAreHome ? match.home_score : match.away_score
  const theirScore = weAreHome ? match.away_score : match.home_score
  return ourScore > theirScore ? 'W' : ourScore < theirScore ? 'L' : 'D'
}

const resultColor = (match) => {
  const r = getResult(match)
  return r === 'W' ? 'badge-success' : r === 'L' ? 'badge-error' : 'badge-warning'
}

const sortedMatches = edition.matches?.sort((a, b) =>
  new Date(a.date) - new Date(b.date)) ?? []
---

<Layout title={`${edition.event.name} ${edition.edition} — FC Boosted`}>

  <a href={`/tournaments/${id}`} class="btn btn-ghost btn-sm mb-6">← Back to {edition.event.name}</a>

  <h1 class="text-4xl font-bold mb-1">{edition.event.name}</h1>
<p class="text-2xl text-base-content/50 mb-4">{edition.edition}</p>

{(() => {
  const ourTeamId = 1
  const entry = edition.teams?.find(e => e.teams_id?.id === ourTeamId || e.teams_id === ourTeamId)
  const placement = entry?.placement
  if (!placement) return null
  return (
    <div class={`alert mb-8 ${
      placement === 1 ? 'alert-success' :
      placement === 2 ? 'bg-base-200' :
      placement === 3 ? 'bg-base-200' :
      'bg-base-200'
    }`}>
      <span class="text-2xl">
        {placement === 1 ? '🏆' : placement === 2 ? '🥈' : placement === 3 ? '🥉' : '🏅'}
      </span>
      <span class="font-bold text-lg">
        FC Boosted finished {placement === 1 ? '1st' : placement === 2 ? '2nd' : placement === 3 ? '3rd' : `${placement}th`} in this tournament
      </span>
    </div>
  )
})()}

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <div class="md:col-span-2">
      <h2 class="text-2xl font-bold mb-4">Matches</h2>
      {sortedMatches.length > 0 ? (
        <div class="flex flex-col gap-3">
          {sortedMatches.map(match => (
            <a href={`/matches/${match.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
              <div class="card-body py-4">
                <div class="flex items-center justify-between gap-4">
                  <p class="flex-1 text-right font-semibold">{match.home_team.name}</p>
                  <div class="flex flex-col items-center gap-1">
  {match.title && <p class="text-xs text-base-content/50">{match.title}</p>}
  <p class="text-2xl font-bold text-primary">{match.home_score} — {match.away_score}</p>
  <span class={`badge ${resultColor(match)}`}>{getResult(match)}</span>
</div>
                  <p class="flex-1 text-left font-semibold">{match.away_team.name}</p>
                </div>
                <p class="text-center text-sm text-base-content/50 mt-1">{formatDate(match.date)}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-base-content/50">No matches recorded yet.</p>
      )}
    </div>

    <!-- Participating Teams -->
<div>
  <h2 class="text-2xl font-bold mb-4">Participating Teams</h2>
  {edition.teams?.length > 0 ? (
    <div class="flex flex-col gap-3">
      {edition.teams
        .sort((a, b) => (a.placement ?? 99) - (b.placement ?? 99))
        .map(({ teams_id: team, placement }) => (
          <a href={`/teams/${team.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
            <div class="card-body p-4 flex-row items-center gap-4">
              {placement && (
                <span class={`text-2xl font-bold w-8 text-center ${
                  placement === 1 ? 'text-yellow-400' :
                  placement === 2 ? 'text-gray-400' :
                  placement === 3 ? 'text-amber-600' :
                  'text-base-content/30'
                }`}>{placement}</span>
              )}
              {team.logo && (
                <img src={getImageUrl(team.logo)} alt={team.name} class="w-10 h-10 object-contain" />
              )}
              <p class="font-semibold">{team.name}</p>
              {placement === 1 && <span class="badge badge-warning ml-auto">🏆 Winner</span>}
            </div>
          </a>
        ))}
    </div>
  ) : (
    <p class="text-base-content/50">No teams recorded yet.</p>
  )}
</div>

  </div>

</Layout>