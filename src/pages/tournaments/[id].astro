---
export const prerender = false
import Layout from '../../layouts/Layout.astro'
import { fetchCollection } from '../../directus.js'

const { id } = Astro.params

const event = await fetchCollection('tournament_events', `/${id}?fields=*,editions.*,editions.teams.teams_id,editions.teams.placement`)

const ourTeamId = 1

const sortedEditions = event.editions?.sort((a, b) =>
  new Date(b.date) - new Date(a.date)) ?? []

const formatDate = (dateStr) => new Date(dateStr).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
})
---

<Layout title={`${event.name} — FC Boosted`}>

  <a href="/tournaments" class="btn btn-ghost btn-sm mb-6">← Back to tournaments</a>

  <h1 class="text-4xl font-bold mb-2">{event.name}</h1>
  {event.bio && <p class="text-base-content/60 mb-8">{event.bio}</p>}

  <h2 class="text-2xl font-bold mb-4">Editions</h2>

  {sortedEditions.length > 0 ? (
    <div class="flex flex-col gap-4">
      {sortedEditions.map(edition => {
  const entry = edition.teams?.find(e => e.teams_id === ourTeamId)
  const placement = entry?.placement
  return (
    <a href={`/tournaments/${id}/editions/${edition.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors shadow-md">
      <div class="card-body py-4 flex-row items-center justify-between">
        <div class="flex items-center gap-4">
          <p class="text-xl font-bold">{edition.edition}</p>
          {placement && (
            <span class={`font-bold ${
              placement === 1 ? 'text-yellow-400' :
              placement === 2 ? 'text-gray-400' :
              placement === 3 ? 'text-amber-600' :
              'text-base-content/50'
            }`}>
              {placement === 1 ? '🏆 1st' : placement === 2 ? '🥈 2nd' : placement === 3 ? '🥉 3rd' : `${placement}th`}
            </span>
          )}
        </div>
        <p class="text-base-content/50">{formatDate(edition.date)}</p>
      </div>
    </a>
  )
})}
    </div>
  ) : (
    <p class="text-base-content/50">No editions recorded yet.</p>
  )}

</Layout>