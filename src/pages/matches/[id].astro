---
export const prerender = false
import Layout from '../../layouts/Layout.astro'
import { fetchCollection, getImageUrl } from '../../directus.js'

const { id } = Astro.params

const match = await fetchCollection('matches',
  `/${id}?fields=*,home_team.*,away_team.*,tournament.id,tournament.edition,tournament.event.id,tournament.event.name,tournament.staff.people_id.*,tournament.staff.role,tournament.staff.team.*,players.people_id.*,players.goals,players.team`)

const formatDate = (dateStr) => new Date(dateStr).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
})

const ourTeamName = 'FC Boosted'
const weAreHome = match.home_team.name === ourTeamName
const ourScore = weAreHome ? match.home_score : match.away_score
const theirScore = weAreHome ? match.away_score : match.home_score
const result = ourScore > theirScore ? 'W' : ourScore < theirScore ? 'L' : 'D'
const resultColor = result === 'W' ? 'text-success' : result === 'L' ? 'text-error' : 'text-warning'
const resultLabel = result === 'W' ? 'Victory' : result === 'L' ? 'Defeat' : 'Draw'

const homePlayers = match.players?.filter(p => p.team === match.home_team.id) ?? []
const awayPlayers = match.players?.filter(p => p.team === match.away_team.id) ?? []

const staffByTeamAndRole = {}
match.tournament?.staff?.forEach(({ people_id: person, role, team }) => {
  const teamName = team?.name ?? 'Unknown'
  if (!staffByTeamAndRole[teamName]) staffByTeamAndRole[teamName] = {}
  if (!staffByTeamAndRole[teamName][role]) staffByTeamAndRole[teamName][role] = []
  staffByTeamAndRole[teamName][role].push(person)
})
---

<Layout title={`${match.home_team.name} vs ${match.away_team.name}`}>

  <a href="/matches" class="btn btn-ghost btn-sm mb-6">← Back to matches</a>

  <!-- Score card -->
  <div class="card bg-base-200 shadow-md mb-8">
    <div class="card-body py-8">
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1 text-center">
          {match.home_team.logo && (
            <img src={getImageUrl(match.home_team.logo)} alt={match.home_team.name} class="w-16 h-16 object-contain mx-auto mb-2" />
          )}
          <p class="text-xl font-bold">{match.home_team.name}</p>
        </div>

        <div class="text-center">
          {match.title && <p class="text-base-content/50 mb-1">{match.title}</p>}
<p class="text-6xl font-bold text-primary">{match.home_score} — {match.away_score}</p>
<p class={`text-2xl font-bold mt-2 ${resultColor}`}>{resultLabel}</p>
        </div>

        <div class="flex-1 text-center">
          {match.away_team.logo && (
            <img src={getImageUrl(match.away_team.logo)} alt={match.away_team.name} class="w-16 h-16 object-contain mx-auto mb-2" />
          )}
          <p class="text-xl font-bold">{match.away_team.name}</p>
        </div>
      </div>

      <div class="divider"></div>

      <div class="flex justify-center gap-8 text-sm text-base-content/50">
        <p>📅 {formatDate(match.date)}</p>
        {match.tournament && (
          <a href={`/tournaments/${match.tournament.event.id}/editions/${match.tournament.id}`} class="hover:text-primary transition-colors">
            🏆 {match.tournament.event.name} — {match.tournament.edition}
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Squad -->
  {(homePlayers.length > 0 || awayPlayers.length > 0) && (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      {homePlayers.length > 0 && (
        <div>
          <h2 class="text-xl font-bold mb-4">{match.home_team.name}</h2>
          <div class="flex flex-col gap-3">
            {homePlayers.map(({ people_id: player, goals }) => (
              <a href={`/people/${player.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
                <div class="card-body p-4 flex-row items-center justify-between">
                  <div class="flex items-center gap-3">
                    {player.photo && (
                      <img src={getImageUrl(player.photo)} alt={player.full_name} class="w-10 h-10 rounded-full object-cover" />
                    )}
                    <p class="font-semibold">{player.full_name}</p>
                  </div>
                  {goals > 0 && (
                    <span class="badge badge-success gap-1">⚽ {goals}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {awayPlayers.length > 0 && (
        <div>
          <h2 class="text-xl font-bold mb-4">{match.away_team.name}</h2>
          <div class="flex flex-col gap-3">
            {awayPlayers.map(({ people_id: player, goals }) => (
              <a href={`/people/${player.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
                <div class="card-body p-4 flex-row items-center justify-between">
                  <div class="flex items-center gap-3">
                    {player.photo && (
                      <img src={getImageUrl(player.photo)} alt={player.full_name} class="w-10 h-10 rounded-full object-cover" />
                    )}
                    <p class="font-semibold">{player.full_name}</p>
                  </div>
                  {goals > 0 && (
                    <span class="badge badge-success gap-1">⚽ {goals}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  )}
  {Object.keys(staffByTeamAndRole).length > 0 && (
  <div class="mt-8">
    <h2 class="text-2xl font-bold mb-4">Staff</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {Object.entries(staffByTeamAndRole).map(([teamName, roles]) => (
        <div class="card bg-base-200 shadow-md">
          <div class="card-body">
            <h3 class="card-title text-lg">{teamName}</h3>
            <div class="flex flex-col gap-3 mt-2">
              {Object.entries(roles).map(([role, people]) => (
                <div class="flex items-start gap-4">
                  <p class="text-sm text-base-content/50 w-36 shrink-0">{role}</p>
                  <div class="flex flex-wrap gap-2">
                    {people.map(person => (
                      <a href={`/people/${person.id}`} class="badge badge-outline hover:badge-primary transition-colors p-3">
                        {person.full_name}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}

</Layout>