---
export const prerender = false
import Layout from '../layouts/Layout.astro'
import { fetchCollection, getImageUrl } from '../directus.js'

const posts = await fetchCollection('posts', '?sort=-published_date&limit=10')
const ourTeamId = 1
const recentMatches = await fetchCollection('matches',
  `?fields=*,home_team.*,away_team.*,title&filter[_or][0][home_team][_eq]=${ourTeamId}&filter[_or][1][away_team][_eq]=${ourTeamId}&sort=-date&limit=5`)
---

<Layout title="FC Boosted">

  <div class="hero bg-base-200 rounded-2xl py-12 mb-10">
    <div class="hero-content text-center">
      <div>
        <h1 class="text-5xl font-bold text-purple-800">FC Boosted</h1>
        <p class="py-4 text-base-content/70">Match reports, player profiles and more</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <div class="md:col-span-2">
      <h2 class="text-2xl font-bold mb-4">Latest Posts</h2>
      <div class="flex flex-col gap-4">
        {posts.map(post => (
          <a href={`/posts/${post.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
            <div class="card-body">
              {post.cover_image && (
                <img src={getImageUrl(post.cover_image)} alt={post.title} class="rounded-xl w-full object-cover h-40 mb-2" />
              )}
              <h3 class="card-title">{post.title}</h3>
              <p class="text-sm text-base-content/50">{new Date(post.published_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-bold mb-4">Recent Results</h2>
      <div class="flex flex-col gap-3">
        {recentMatches.map(match => (
          <a href={`/matches/${match.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
            <div class="card-body p-4">
              {match.title && <p class="text-xs text-base-content/50 text-center">{match.title}</p>}
<p class="text-sm font-semibold">{match.home_team.name}</p>
<p class="text-2xl font-bold text-primary text-center">{match.home_score} — {match.away_score}</p>
<p class="text-sm font-semibold text-right">{match.away_team.name}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>

</Layout>